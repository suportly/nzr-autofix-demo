# ============================================================
# NZR Autofix Demo — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Get your DSN and endpoint from:
#   NZR Manager > Autofix > Projects > [Your Project] > DSN
# ============================================================

# --- Backend (Python SDK) ---
NZR_AUTOFIX_DSN=nzr://your-token-here@autofix/your-project-id
NZR_AUTOFIX_ENDPOINT_URL=https://your-nzr-instance.com/api/v1/autofix/ingest/
NZR_AUTOFIX_ENVIRONMENT=demo
DJANGO_SECRET_KEY=demo-secret-key-change-in-production

# --- Frontend (JavaScript SDK) ---
# Vite requires VITE_ prefix for env vars exposed to the browser
VITE_NZR_AUTOFIX_DSN=nzr://your-token-here@autofix/your-project-id
VITE_NZR_AUTOFIX_ENDPOINT_URL=https://your-nzr-instance.com/api/v1/autofix/ingest/
VITE_NZR_AUTOFIX_ENVIRONMENT=demo
VITE_API_URL=http://localhost:8000
